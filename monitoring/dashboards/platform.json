{
  "title": "Platform Overview",
  "uid": "dam-platform-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(kube_pod_info, namespace)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Node CPU Usage",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Node Memory Usage",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{instance}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Node Ready Status",
      "type": "stat",
      "datasource": "${datasource}",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(kube_node_status_condition{condition=\"Ready\", status=\"true\"})",
          "legendFormat": "Ready nodes"
        }
      ]
    },
    {
      "id": 4,
      "title": "Pods by Phase",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum by (namespace, phase) (kube_pod_status_phase{namespace=~\"$namespace\"})",
          "legendFormat": "{{namespace}} / {{phase}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Container Restart Rate",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum by (namespace, pod) (rate(kube_pod_container_status_restarts_total{namespace=~\"$namespace\"}[15m])) > 0",
          "legendFormat": "{{namespace}}/{{pod}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Deployment Replicas: Desired vs Available",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (namespace, deployment) (kube_deployment_status_replicas{namespace=~\"$namespace\"})",
          "legendFormat": "{{namespace}}/{{deployment}} desired"
        },
        {
          "expr": "sum by (namespace, deployment) (kube_deployment_status_replicas_available{namespace=~\"$namespace\"})",
          "legendFormat": "{{namespace}}/{{deployment}} available"
        }
      ]
    },
    {
      "id": 7,
      "title": "PVC Usage",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "kubelet_volume_stats_used_bytes{namespace=~\"$namespace\"} / kubelet_volume_stats_capacity_bytes{namespace=~\"$namespace\"}",
          "legendFormat": "{{namespace}}/{{persistentvolumeclaim}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Node Network I/O",
      "type": "timeseries",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "{{instance}} rx {{device}}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*\"}[5m])",
          "legendFormat": "{{instance}} tx {{device}}"
        }
      ]
    }
  ]
}
